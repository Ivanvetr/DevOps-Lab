{
  "title": "DevOps Lab - Flask App",
  "uid": "devops-lab-dashboard",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Peticiones por segundo (por endpoint)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(flask_http_request_total{app=\"devops-lab-service\"}[1m])) by (path)",
          "legendFormat": "{{path}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Latencia promedio (p95) por endpoint",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(flask_http_request_duration_seconds_bucket{app=\"devops-lab-service\"}[5m])) by (le, path))",
          "legendFormat": "p95 {{path}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Errores HTTP 5xx (tasa)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(flask_http_request_total{app=\"devops-lab-service\", status=~\"5..\"}[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.1 }
            ]
          },
          "unit": "reqps"
        }
      }
    },
    {
      "id": 4,
      "title": "Pods activos (devops-lab)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "count(kube_pod_status_phase{namespace=\"devops-lab\", phase=\"Running\"})",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Uso de CPU por pod (devops-lab)",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"devops-lab\"}[5m])) by (pod)",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Uso de memoria por pod (devops-lab)",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes{namespace=\"devops-lab\"}) by (pod)",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ]
    }
  ]
}
